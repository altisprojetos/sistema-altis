generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String          @id @default(cuid())
  name              String
  email             String          @unique
  password          String
  commissionRate    Float           @default(0)
  active            Boolean         @default(true)
  createdAt         DateTime        @default(now())
  roles             Role[]
  clientsSold       Client[]
  clientNotes       ClientNote[]
  commissions       Commission[]
  approvedCosts     Cost[]          @relation("CostApprover")
  costs             Cost[]          @relation("CostCreator")
  processesAnalyzed Process[]       @relation("Analyst")
  processesSold     Process[]       @relation("Seller")
  tasksAssigned     Task[]          @relation("AssignedTo")
  tasksCreated      Task[]          @relation("CreatedBy")
  taskComments      TaskComment[]
  timelineEntries   TimelineEntry[]
}

model Client {
  id            String           @id @default(cuid())
  name          String
  document      String?
  phone         String?
  email         String?
  address       String?
  type          ClientType       @default(RURAL)
  farmName      String?
  municipality  String?
  areaHa        Float?
  latitude      Float?
  longitude     Float?
  sellerId      String
  createdAt     DateTime         @default(now())
  propertyCount Int              @default(1)
  seller        User             @relation(fields: [sellerId], references: [id])
  notes         ClientNote[]
  properties    ClientProperty[]
  processes     Process[]
}

model ClientProperty {
  id            String           @id @default(cuid())
  clientId      String
  index         Int
  farmName      String?
  municipality  String?
  areaHa        Float?
  latitude      Float?
  longitude     Float?
  streetAddress String?
  neighborhood  String?
  city          String?
  state         String?
  cep           String?
  client        Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  services      ProcessService[]
}

model ClientNote {
  id        String   @id @default(cuid())
  clientId  String
  userId    String
  content   String
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Process {
  id                     String                @id @default(cuid())
  clientId               String
  sellerId               String
  analystId              String?
  salesStage             SalesStage            @default(PROSPECCAO)
  opsStage               OpsStage?
  totalValue             Float?
  negotiatedValue        Float?
  negotiationReason      String?
  paymentMethod          PaymentMethod?
  installments           Int?
  expectedCompletionDate DateTime?
  contractStatus         ContractStatus        @default(PENDENTE)
  contractMethod         ContractMethod?
  contractSignedAt       DateTime?
  bankPaymentStartDate   DateTime?
  bankPaymentCount       Int?
  bankPaymentInterval    String?
  sentToOpsAt            DateTime?
  completedAt            DateTime?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  contractFileUrl        String?
  paymentLabel           String?
  bankReminders          BankPaymentReminder[]
  commissions            Commission[]
  costs                  Cost[]
  devolutions            Devolution[]
  documents              Document[]
  analyst                User?                 @relation("Analyst", fields: [analystId], references: [id])
  client                 Client                @relation(fields: [clientId], references: [id])
  seller                 User                  @relation("Seller", fields: [sellerId], references: [id])
  services               ProcessService[]
  prospections           Prospection[]
  reminders              Reminder[]
  tasks                  Task[]
  timeline               TimelineEntry[]
}

model ProcessService {
  id                String          @id @default(cuid())
  processId         String
  serviceGroup      String
  serviceKey        String
  serviceName       String
  subtype           String?
  hectares          Float?
  squareMeters      Float?
  confrontantes     Int?
  financedValue     Float?
  calculatedValue   Float?
  negotiatedValue   Float?
  negotiationReason String?
  clientPropertyId  String?
  propertyIds       String?
  clientProperty    ClientProperty? @relation(fields: [clientPropertyId], references: [id])
  process           Process         @relation(fields: [processId], references: [id], onDelete: Cascade)
}

model Document {
  id            String   @id @default(cuid())
  processId     String
  docNumber     Int
  docName       String
  fileName      String
  url           String
  propertyIndex Int      @default(0)
  uploadedAt    DateTime @default(now())
  uploadedBy    String
  description   String?
  process       Process  @relation(fields: [processId], references: [id], onDelete: Cascade)
}

model Devolution {
  id         String    @id @default(cuid())
  processId  String
  pendencies String
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
  process    Process   @relation(fields: [processId], references: [id], onDelete: Cascade)
}

model TimelineEntry {
  id        String   @id @default(cuid())
  processId String
  userId    String
  stage     String
  content   String
  createdAt DateTime @default(now())
  process   Process  @relation(fields: [processId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model Reminder {
  id          String    @id @default(cuid())
  processId   String
  institution String
  description String
  dueDate     DateTime
  done        Boolean   @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  process     Process   @relation(fields: [processId], references: [id], onDelete: Cascade)
}

model BankPaymentReminder {
  id          String    @id @default(cuid())
  processId   String
  dueDate     DateTime
  notifiedAt  DateTime?
  confirmed   Boolean   @default(false)
  confirmedAt DateTime?
  createdAt   DateTime  @default(now())
  process     Process   @relation(fields: [processId], references: [id], onDelete: Cascade)
}

model Task {
  id           String        @id @default(cuid())
  processId    String
  title        String
  description  String?
  createdById  String
  assignedToId String
  status       TaskStatus    @default(PENDENTE)
  dueDate      DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  assignedTo   User          @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdBy    User          @relation("CreatedBy", fields: [createdById], references: [id])
  process      Process       @relation(fields: [processId], references: [id], onDelete: Cascade)
  comments     TaskComment[]
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model Commission {
  id             String           @id @default(cuid())
  userId         String
  processId      String
  amount         Float
  originalAmount Float?
  adjustmentNote String?
  status         CommissionStatus @default(PENDENTE)
  paidAt         DateTime?
  paidById       String?
  createdAt      DateTime         @default(now())
  process        Process          @relation(fields: [processId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id])
}

model Cost {
  id              String             @id @default(cuid())
  description     String
  amount          Float
  type            CostType
  month           Int
  year            Int
  category        String?
  date            DateTime           @default(now())
  createdAt       DateTime           @default(now())
  processId       String?
  userId          String?
  approvalStatus  CostApprovalStatus @default(PENDENTE)
  approvedAt      DateTime?
  approvedById    String?
  owner           CostOwner          @default(EMPRESA)
  receiptUrl      String?
  rejectionReason String?
  approvedBy      User?              @relation("CostApprover", fields: [approvedById], references: [id])
  process         Process?           @relation(fields: [processId], references: [id])
  user            User?              @relation("CostCreator", fields: [userId], references: [id])
}

model AccountEntry {
  id          String    @id @default(cuid())
  description String
  amount      Float
  type        EntryType
  category    String?
  date        DateTime  @default(now())
  createdAt   DateTime  @default(now())
}

model Prospection {
  id              String    @id @default(cuid())
  processId       String
  sellerId        String
  notes           String?
  dismissed       Boolean   @default(false)
  dismissedAt     DateTime?
  nextContactDate DateTime?
  createdAt       DateTime  @default(now())
  process         Process   @relation(fields: [processId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  VENDEDOR
  OPERADOR
  FINANCEIRO
  COORDENADOR
}

enum SalesStage {
  PROSPECCAO
  SERVICO_FECHADO
  DOCUMENTACAO_COLETADA
  ENVIADO_OPERACAO
  DEVOLVIDO_PENDENCIAS
}

enum OpsStage {
  A_INICIAR
  ELABORAR
  ANALISE
  DEVOLVIDO
  PARALISADO
  FINALIZADO
}

enum TaskStatus {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDA
}

enum CommissionStatus {
  PENDENTE
  PAGA
}

enum ContractMethod {
  ZAPSIGN
  FISICO
}

enum ContractStatus {
  PENDENTE
  ASSINADO
}

enum PaymentMethod {
  AVISTA
  PARCELADO
}

enum ClientType {
  RURAL
  URBANO
}

enum CostType {
  FIXO
  VARIAVEL
}

enum CostOwner {
  EMPRESA
  CLIENTE
}

enum CostApprovalStatus {
  PENDENTE
  APROVADO
  REJEITADO
}

enum EntryType {
  ENTRADA
  SAIDA
}
